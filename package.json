{
  "name": "helix-agent-framework",
  "version": "0.10.2",
  "description": "Helix — Local-first AI Agent Framework",
  "type": "module",
  "main": "src/server-lite.js",
  "bin": {
    "helix": "./bin/helix.js"
  },
  "scripts": {
    "start": "node bin/helix.js start",
    "init": "node bin/helix.js init",
    "test": "node --test tests/*.test.mjs",
    "build:bundle": "esbuild bin/helix.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/helix-bundle.mjs --external:better-sqlite3 --external:pg --banner:js='import { createRequire } from \"module\"; const require = createRequire(import.meta.url);'",
    "tauri:dev": "npx @tauri-apps/cli@2.10.1 dev -c desktop/tauri/src-tauri/tauri.conf.json",
    "tauri:build": "npx @tauri-apps/cli@2.10.1 build -c desktop/tauri/src-tauri/tauri.conf.json"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.1.0",
    "pg": "^8.20.0"
  },
  "keywords": [
    "ai",
    "agent",
    "framework",
    "helix",
    "local-first"
  ],
  "license": "MIT",
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
